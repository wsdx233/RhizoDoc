{
  "name": "rhizodoc",
  "version": "1.0.0",
  "description": "RhizoDoc：面向研究与长文档分析的 AI 文档图谱无限画布，使用 Pi 模型配置接入多模型供应商。",
  "type": "module",
  "packageManager": "pnpm@11.3.0",
  "main": "server.ts",
  "scripts": {
    "start": "tsx server.ts",
    "serve": "tsx server.ts",
    "dev": "concurrently -k -n API,WEB -c cyan,magenta \"RHIZODOC_DEV=1 tsx watch server.ts\" \"vite --host 0.0.0.0\"",
    "dev:api": "RHIZODOC_DEV=1 tsx watch server.ts",
    "dev:web": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "pnpm build && tsx server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@highlightjs/cdn-assets": "^11.11.1",
    "@shikijs/stream": "^4.2.0",
    "dompurify": "^3.4.7",
    "express": "^5.2.1",
    "katex": "^0.17.0",
    "marked": "^12.0.2",
    "shiki": "^4.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "prettier": "^3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=22.19.0"
  }
}
