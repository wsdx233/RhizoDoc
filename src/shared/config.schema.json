{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RhizoDoc Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "server": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string", "default": "127.0.0.1" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 3000 },
        "jsonLimit": { "type": "string", "default": "20mb" }
      }
    },
    "pi": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "default": "" },
        "model": { "type": "string", "default": "" },
        "thinkingLevel": { "type": "string", "default": "" },
        "maxTokens": { "type": "integer", "minimum": 1, "maximum": 200000, "default": 12000 }
      }
    },
    "storage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flowsDir": { "type": "string", "default": "data/flows" }
      }
    },
    "tools": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "search": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "extensionPaths": {
              "type": "array",
              "items": { "type": "string" },
              "default": []
            },
            "allowedTools": {
              "type": "array",
              "items": { "type": "string" },
              "default": ["grok_search", "kimi_search", "gemini_search"]
            },
            "maxToolCalls": { "type": "integer", "minimum": 0, "maximum": 64, "default": 8 }
          }
        }
      }
    }
  }
}
